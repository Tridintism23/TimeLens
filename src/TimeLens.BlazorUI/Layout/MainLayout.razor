@inherits LayoutComponentBase
@inject AuthService AuthService
@inject NavigationManager Navigation

<MudLayout>
    <MudAppBar Color="Color.Primary" Fixed="true">
        <MudText Typo="Typo.h6">⏳ TimeLens</MudText>
        <MudSpacer />
        <MudIconButton Icon="@Icons.Material.Filled.Book"
                       Color="Color.Inherit" Href="/journals" />
        <MudIconButton Icon="@Icons.Material.Filled.Chat"
                       Color="Color.Inherit" Href="/chat" />
        <MudIconButton Icon="@Icons.Material.Filled.Logout"
                       Color="Color.Inherit" OnClick="Logout" />
    </MudAppBar>

    <MudDrawer Open="true" Variant="DrawerVariant.Mini" Color="Color.Dark">
        <MudNavMenu>
            <MudNavLink Href="/journals" Icon="@Icons.Material.Filled.Book">
                Nhật ký
            </MudNavLink>
            <MudNavLink Href="/chat" Icon="@Icons.Material.Filled.Chat">
                Chat với quá khứ
            </MudNavLink>
            <MudNavLink Href="/dashboard" Icon="@Icons.Material.Filled.Dashboard">
                Dashboard
            </MudNavLink>
        </MudNavMenu>
    </MudDrawer>

    <MudMainContent Class="pt-16 px-4">
        <MudContainer MaxWidth="MaxWidth.Large" Class="my-4">
            @Body
        </MudContainer>
    </MudMainContent>
</MudLayout>

@code {
    void Logout()
    {
        AuthService.Logout();
        Navigation.NavigateTo("/login", true);
    }
}